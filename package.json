{
	"name": "@dariah-eric/dariah-website",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.x",
			"onFail": "download"
		}
	},
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"analyze": "next experimental-analyze --experimental-next-config-strip-types",
		"build": "next build --experimental-next-config-strip-types",
		"dev": "next dev --experimental-next-config-strip-types",
		"dev:services:down": "docker compose --env-file ./.env.local --file ./docker-compose.yaml down --volumes",
		"dev:services:up": "docker compose --env-file ./.env.local --file ./docker-compose.yaml up --detach",
		"format:check": "prettier . --cache --cache-location ./.prettiercache --check",
		"format:fix": "prettier . --cache --cache-location ./.prettiercache --check --write",
		"generate:api": "dotenvx run -f ./.env.local --ignore MISSING_ENV_FILE -- tsx ./scripts/openapi/generate.ts",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:code:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"lint:styles:check": "stylelint \"./styles/**/*.css\" --cache --ignore-path ./.gitignore",
		"lint:styles:fix": "stylelint \"./styles/**/*.css\" --cache --fix --ignore-path ./.gitignore",
		"prepare": "run-s setup types:prepare generate:api",
		"search-index:api-keys:generate": "dotenvx run -f ./.env.local --ignore MISSING_ENV_FILE -- tsx ./scripts/search-index/generate-search-api-key.ts",
		"search-index:collections:create": "dotenvx run -f ./.env.local --ignore MISSING_ENV_FILE -- tsx ./scripts/search-index/create-collection.ts",
		"search-index:collections:seed": "dotenvx run -f ./.env.local --ignore MISSING_ENV_FILE -- tsx ./scripts/search-index/seed.ts",
		"setup": "is-in-ci || simple-git-hooks",
		"start": "next start --experimental-next-config-strip-types",
		"storybook:build": "storybook build",
		"storybook:dev": "storybook dev --no-open --port 6006",
		"test:e2e": "playwright test --config ./e2e/playwright.config.ts",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "pnpm run test:e2e --ui",
		"test:e2e:update-snapshots": "pnpm run test:e2e --update-snapshots",
		"types:check": "tsc --noEmit",
		"types:prepare": "ENV_VALIDATION=\"disabled\" next typegen"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^0.3.7",
		"@acdh-oeaw/style-variants": "^0.1.0",
		"@acdh-oeaw/validate-env": "^0.2.1",
		"@faker-js/faker": "^10.4.0",
		"@internationalized/date": "^3.12.1",
		"@opentelemetry/api": "^1.9.1",
		"@react-aria/utils": "^3.34.0",
		"@tiptap/core": "^3.22.3",
		"@tiptap/extension-heading": "^3.22.3",
		"@tiptap/starter-kit": "^3.22.3",
		"@tiptap/static-renderer": "^3.22.3",
		"@vercel/otel": "^2.1.2",
		"algoliasearch": "^5.50.2",
		"better-result": "^2.8.2",
		"client-only": "^0.0.1",
		"clsx": "^2.1.1",
		"is-network-error": "^1.3.1",
		"leaflet": "^1.9.4",
		"lucide-react": "^1.8.0",
		"next": "^16.2.4",
		"next-intl": "^4.9.1",
		"react": "^19.2.5",
		"react-aria": "^3.48.0",
		"react-aria-components": "^1.17.0",
		"react-dom": "^19.2.5",
		"react-instantsearch": "^7.29.0",
		"react-leaflet": "5.0.0",
		"react-multi-carousel": "^2.8.6",
		"react-schemaorg": "^2.0.1",
		"server-only": "^0.0.1",
		"sharp": "^0.34.5",
		"typesense": "^2.1.0",
		"typesense-instantsearch-adapter": "^2.9.0",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^2.0.13",
		"@acdh-oeaw/eslint-config-next": "^4.0.7",
		"@acdh-oeaw/eslint-config-node": "^2.0.13",
		"@acdh-oeaw/eslint-config-playwright": "^2.0.15",
		"@acdh-oeaw/eslint-config-react": "^3.0.6",
		"@acdh-oeaw/eslint-config-storybook": "^4.0.2",
		"@acdh-oeaw/eslint-config-tailwindcss": "^4.1.4",
		"@acdh-oeaw/prettier-config": "^2.0.1",
		"@acdh-oeaw/stylelint-config": "^3.0.3",
		"@acdh-oeaw/tsconfig": "^1.5.1",
		"@dotenvx/dotenvx": "^1.61.0",
		"@next/eslint-plugin-next": "^16.2.4",
		"@playwright/test": "^1.59.1",
		"@sindresorhus/slugify": "^3.0.0",
		"@storybook/nextjs-vite": "^10.3.5",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"axe-core": "^4.11.3",
		"axe-playwright": "^2.2.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.4",
		"eslint-config-flat-gitignore": "^2.3.0",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-perfectionist": "^5.8.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^16.5.0",
		"is-in-ci": "^2.0.0",
		"lint-staged": "^16.4.0",
		"npm-run-all2": "^8.0.4",
		"null-loader": "^4.0.1",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.3",
		"schema-dts": "^2.0.0",
		"simple-git-hooks": "^2.13.1",
		"storybook": "^10.3.5",
		"stylelint": "^17.8.0",
		"tailwindcss": "^4.2.2",
		"tailwindcss-react-aria-components": "^2.1.0",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.8"
	},
	"lint-staged": {
		"*.@(js|ts|tsx)": [
			"eslint --fix --flag unstable_native_nodejs_ts_config",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.@(css)": [
			"stylelint --cache --fix",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.!(css|js|ts|tsx)": "prettier --cache --cache-location ./.prettiercache --ignore-unknown --write"
	},
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	},
	"prettier": "@acdh-oeaw/prettier-config",
	"simple-git-hooks": {
		"pre-commit": "pnpm exec lint-staged"
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	}
}
